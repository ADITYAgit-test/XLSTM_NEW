# nnUNet Environment Variables
# Copy this file to .env and fill in your paths

# nnUNet data directories
nnUNet_raw=/path/to/your/nnUNet_raw
nnUNet_preprocessed=/path/to/your/nnUNet_preprocessed
nnUNet_results=/path/to/your/nnUNet_results

# CUDA settings (optional)
CUDA_VISIBLE_DEVICES=0

# Python path (optional)
PYTHONPATH=/path/to/xLSTM-UNet-PyTorch:$PYTHONPATH